#!/usr/bin/env bash
set -euo pipefail

VERBOSE=0
while getopts ":v" opt; do
    case "$opt" in
        v) VERBOSE=1 ;;
        *)
            echo "Usage: $0 [-v] <chart-name>" >&2
            exit 1
            ;;
    esac
done
shift $((OPTIND - 1))

if [ $# -ne 1 ]; then
    echo "Usage: $0 [-v] <chart-name>" >&2
    echo "  Compiles charts/<chart-name>.gs -> charts/<chart-name>.ly -> charts/<chart-name>.pdf" >&2
    exit 1
fi

NAME="$1"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CHARTS_DIR="$SCRIPT_DIR/charts"
GS_FILE="$CHARTS_DIR/${NAME}.gs"
LY_FILE="$CHARTS_DIR/${NAME}.ly"

if [ ! -f "$GS_FILE" ]; then
    echo "Error: $GS_FILE not found" >&2
    exit 1
fi

if [ "$VERBOSE" -eq 1 ]; then
    echo "Compiling $GS_FILE -> $LY_FILE"
    uv run groovescript compile "$GS_FILE" -o "$LY_FILE"
    echo "Rendering $LY_FILE -> $CHARTS_DIR/${NAME}.pdf"
    lilypond -o "$CHARTS_DIR/$NAME" "$LY_FILE"
    echo "Done: $CHARTS_DIR/${NAME}.pdf"
else
    uv run groovescript compile "$GS_FILE" -o "$LY_FILE" >/dev/null
    lilypond -o "$CHARTS_DIR/$NAME" "$LY_FILE" >/dev/null 2>&1
fi
