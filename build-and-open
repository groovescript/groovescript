#!/usr/bin/env bash
set -euo pipefail

if [ $# -ne 1 ]; then
    echo "Usage: $0 <chart-name>" >&2
    echo "  Builds charts/<chart-name>.pdf and opens it (macOS)" >&2
    exit 1
fi

NAME="$1"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

"$SCRIPT_DIR/build-pdf" "$NAME"
open "$SCRIPT_DIR/charts/${NAME}.pdf"
